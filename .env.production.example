# Required in all modes
PAYLOAD_SECRET=replace_with_long_random_secret
CLOUDFLARE_TUNNEL_TOKEN=replace_with_tunnel_token

# PostgreSQL (used in all-in-one stack mode)
POSTGRES_USER=app
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=appdb

DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# SeaweedFS S3 Gateway (for media storage)
S3_ACCESS_KEY_ID=replace_with_access_key
S3_SECRET_ACCESS_KEY=replace_with_secret_key
S3_BUCKET=media
S3_ENDPOINT=http://seaweedfs-s3:8333
S3_REGION=us-east-1

# Optional: if set, compose.prod.yml tags built payload image with this name
PAYLOAD_IMAGE=45th-homepage:local

# Required: strict health check requires this header value
# x-health-key: <HEALTH_CHECK_KEY>
HEALTH_CHECK_KEY=replace_with_healthcheck_key
